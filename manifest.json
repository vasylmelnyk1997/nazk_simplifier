{
  "manifest_version": 3,
  "name": "NAZK Data Simplifier",
  "version": "1.0",
  "description": "Приховує блоки на сайті НАЗК за текстом",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "NAZK Simplifier"
  },
  "content_scripts": [
    {
      "matches": ["https://public.nazk.gov.ua/documents/*"],
      "js": ["tools.js", "specs.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
